APP_NAME="Smart Farm Irrigation Backend"
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Kolkata
APP_BASE_URL=https://yourdomain.com/backend

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=smart_irrigation
DB_USER=db_user
DB_PASS=db_password

# Generate with: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=changeme_generate_a_64_char_random_secret
JWT_ISSUER=smart-farm-irrigation
JWT_TTL=3600

OPENWEATHER_API_KEY=

RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60
